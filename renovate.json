{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboardAutoclose": true,
  "packageRules": [
    {
      "description": "Automerge Maven and Maven Wrapper updates",
      "matchDepNames": ["maven","maven-wrapper"],
      "automerge": true
    },
    {
      "description": "Automerge updates for test-scoped dependencies",
      "matchManagers": ["maven","gradle"],
      "matchDepTypes": ["test"],
      "automerge": true
    },
    {
      "description": "Automerge update for test library BOMs",
      "matchManagers": ["maven","gradle"],
      "matchDepNames": [
        "org.junit:junit-bom",
        "org.junit.jupiter:junit-jupiter-bom",
        "org.mockito:mockito-bom",
        "org.testcontainers:testcontainers-bom"
      ],
      "automerge": true
    },
    {
      "description": "Automerge SLF4J BOM",
      "matchManagers": ["maven","gradle"],
      "matchDepNames": [
        "org.slf4j:slf4j-bom"
      ],
      "automerge": true
    },
    {
      "description": "Automerge Lombok updates",
      "matchManagers": ["maven","gradle"],
      "matchDepNames": ["org.projectlombok:lombok"],
      "automerge": true
    },
    {
      "description": "Automerge default Maven plugin updates",
      "matchDepNames": ["org.apache.maven.plugins:*"],
      "automerge": true
    },
    {
      "description": "Automerge Quarkus updates (3.33 LTS version)",
      "matchManagers": ["maven","gradle"],
      "matchDepNames": [
        "io.quarkus.platform:quarkus-bom",
        "io.quarkus.platform:quarkus-maven-plugin"
      ],
      "allowedVersions": "<3.34",
      "automerge": true
    }
  ]
}
